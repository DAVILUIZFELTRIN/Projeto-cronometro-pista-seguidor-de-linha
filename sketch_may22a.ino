// =======================
// ROTAS
// =======================
void handleRoot() {
  server.send(200, "text/html", html);
}

void handleDados() {

  if (cronometroAtivo) {
    tempoAtual = millis() - tempoInicio;
  }

  float tempoSeg = tempoAtual / 1000.0;

  String json = "{";
  json += "\"tempo\":\"" + String(tempoSeg, 3) + "\",";
  json += "\"estado\":\"" + estado + "\"";
  json += "}";

  server.send(200, "application/json", json);
}

void handleReset() {

  cronometroAtivo = false;
  corridaFinalizada = false;

  tempoInicio = 0;
  tempoAtual = 0;

  estado = "Aguardando";

  server.send(200, "text/plain", "OK");
}

// =======================
// SETUP
// =======================
void setup() {

  Serial.begin(115200);

  // SENSOR IR
  pinMode(SENSOR_IR, INPUT_PULLUP);

  ledcAttach(IR_LED, 38000, 8);

  ledcWrite(IR_LED, 128);

  // WIFI
  WiFi.softAP(ssid, password);

  Serial.println("AP iniciado");
  Serial.println(WiFi.softAPIP());

  server.on("/", []() {
    server.send(200, "text/html", html);
  });

  server.on("/tempo", []() {

    String resposta;

    if (cronometroAtivo) {
      tempoAtual = millis() - tempoInicio;
    }

    resposta = String(tempoAtual / 1000.0, 3);

    server.send(200, "text/plain", resposta);
  });

  server.on("/estado", []() {
    server.send(200, "text/plain", estado);
  });

  server.begin();
}

// =======================
// LOOP
// =======================
void loop() {
bool estadoAtual = digitalRead(SENSOR_IR);

// detecta interrupção da barreira
if (estadoAtual == LOW && ultimoEstado == HIGH) {

    if (millis() - ultimoTrigger > cooldown) {

        ultimoTrigger = millis();

        Serial.println("BARREIRA INTERROMPIDA");

        // inicia
        if (!cronometroAtivo && !corridaFinalizada) {

            cronometroAtivo = true;

            tempoInicio = millis();

            estado = "Cronômetro iniciado";

            Serial.println("INICIADO");
        }

        // pausa
        else if (cronometroAtivo) {

            cronometroAtivo = false;

            tempoAtual = millis() - tempoInicio;

            corridaFinalizada = true;

            estado = "Finalizado";

            Serial.println("PARADO");
        }
    }
}

ultimoEstado = estadoAtual;
  
}